{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/projects",
      "destination": "/"
    },
    {
      "source": "/project",
      "destination": "/"
    },
    {
      "source": "/stack",
      "destination": "/"
    }
  ]
}
